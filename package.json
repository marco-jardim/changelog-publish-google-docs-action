{
  "name": "changelog-publish-google-docs-action",
  "version": "1.0.0",
  "description": "GitHub Action to publish changelog markdown to Google Docs with idempotency support",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --license licenses.txt",
    "test": "jest --forceExit",
    "test:coverage": "jest --coverage --forceExit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --ext .ts",
    "prebuild": "npm run typecheck"
  },
  "keywords": [
    "github-actions",
    "changelog",
    "google-docs",
    "google-docs-api"
  ],
  "author": "Marco Jardim",
  "license": "GPL-3.0",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "googleapis": "^144.0.0",
    "marked": "^12.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@vercel/ncc": "^0.38.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 70
      }
    }
  }
}
